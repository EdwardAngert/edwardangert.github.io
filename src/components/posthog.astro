  // Public project (ingest) token, safe to expose client-side.
  posthog.init('phc_uNHc6uouvr63MeScHM5RK83wRChPgm9uFRtkhSiuVTm5', {
    api_host: 'https://us.i.posthog.com',
    defaults: '2026-01-30'
  });

  document.addEventListener('click', function(event) {
    var target = event.target.closest('a');
    if (!target || !target.href) return;

    var href = target.href;
    var linkText = target.textContent.trim();

    // contact_link_clicked: LinkedIn or cal.com links
    if (href.includes('linkedin.com') || href.includes('cal.com')) {
      window.posthog?.capture('contact_link_clicked', {
        link_url: href,
        link_text: linkText,
        platform: href.includes('linkedin.com') ? 'linkedin' : 'cal_com'
      });
      return;
    }

    // pdf_downloaded: links to PDF files
    if (href.endsWith('.pdf') || href.includes('/pdfs/')) {
      window.posthog?.capture('pdf_downloaded', {
        link_url: href,
        link_text: linkText
      });
      return;
    }

    // github_project_link_clicked: GitHub project links (repos only).
    // Trailing slash excludes the bare-profile social icon (github.com/EdwardAngert);
    // the edwardangert.github.io exclusion drops "Edit page" / "submit issue" links.
    if (
      (href.includes('github.com/EdwardAngert/') && !href.includes('/edwardangert.github.io')) ||
      href.includes('github.com/coder/shared-docs-kb')
    ) {
      window.posthog?.capture('github_project_link_clicked', {
        link_url: href,
        link_text: linkText
      });
      return;
    }

    // external_docs_link_clicked: external documentation sample links.
    // (linode.com / akamai.com dropped: neither is hyperlinked anywhere on the site.)
    if (
      href.includes('docs.gitlab.com') ||
      href.includes('github.com/coder/coder')
    ) {
      window.posthog?.capture('external_docs_link_clicked', {
        link_url: href,
        link_text: linkText
      });
      return;
    }

    // portfolio_item_clicked: internal portfolio item links from the portfolio overview
    var fromPortfolioOverview = window.location.pathname === '/portfolio/' || window.location.pathname === '/portfolio';
    if (fromPortfolioOverview && (href.includes('/portfolio/') || href.includes('/docs/pi-hole/'))) {
      window.posthog?.capture('portfolio_item_clicked', {
        link_url: href,
        link_text: linkText
      });
    }
  });
</script>
